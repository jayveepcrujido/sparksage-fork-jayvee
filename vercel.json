{
   "version": 2,
   "builds": [
     {
       "src": "dashboard/package.json",
       "use": "@vercel/next",
       "config": { "maxLambdaSize": "50mb" }
     },
     {
       "src": "api/main.py",
       "use": "@vercel/python",
       "config": { "maxLambdaSize": "50mb" }
     }
   ],
   "routes": [
     {
       "src": "/api/auth/(.*)",
       "dest": "/api/main.py"
     },
     {
       "src": "/api/(.*)",
       "dest": "/api/main.py"
     },
     {
       "src": "/(.*)",
       "dest": "dashboard/$1"
     }
   ],
   "installCommand": "pip install -r requirements.txt && npm install --prefix dashboard"
}